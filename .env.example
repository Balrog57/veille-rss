# Required: single shared password for all users
APP_PASSWORD=changeme

# Required: used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# Ollama model for French summarization (default: qwen2.5:1.5b)
# Upgrade option: qwen2.5:3b (requires ~2 GB RAM)
OLLAMA_MODEL=qwen2.5:1.5b

# Timezone (must match cron schedule)
TZ=Europe/Paris

# Database path inside the container
DATABASE_PATH=/app/data/veille.sqlite

# Ollama URL (internal Docker network)
OLLAMA_URL=http://ollama:11434

# Frontend origin(s) for CORS.
# If accessing from another device (e.g. ZimaOS at 192.168.1.98:3000),
# add that origin too, comma-separated:
#   FRONTEND_ORIGIN=http://192.168.1.98:3000,http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Set to "true" if the app is served behind HTTPS (secure cookie flag)
SECURE_COOKIE=false

# --- Runtime settings (overridden at runtime via the /admin/settings page) ---

# Default timezone (IANA). Used by bucket math and cron schedule.
# TZ=Europe/Paris

# Default cron expression (5-field). "0 */6 * * *" = every 6h on the hour.
# CRON_EXPR=0 */6 * * *

# Default article retention in days. Old editions/articles are pruned
# nightly at 03:05 (timezone) and can be pruned manually from the UI.
# RETENTION_DAYS=90

# Default max article age in hours. Articles older than this are ignored
# when ingesting (prevents stale articles in fresh editions).
# MAX_ARTICLE_AGE_HOURS=48

# Where the runtime settings file is stored (default: <data>/settings.json)
# SETTINGS_PATH=/app/data/settings.json
